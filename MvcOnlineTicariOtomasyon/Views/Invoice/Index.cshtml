@using MvcOnlineTicariOtomasyon.Models.Entities
@model List<Invoice>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />
<h2>Faturalar</h2>
<table class="table table-bordered">
    <tr>
        <th>Seri Sıra No</th>
        <th>Tarih</th>
        <th>Saat</th>
        <th>Toplam</th>
        <th>Güncelle</th>
        <th>Detaylar</th>
        <th>Yeni Kalem</th>
    </tr>
    @foreach (var x in Model)
    {
<tr>
    <td>@x.InvoiceSerialNo @x.InvoiceSequenceNo</td>
    <td>@x.Date</td>
    <td>@x.Time</td>
    <td>@x.Total ₺</td>
    <td><a href="/Invoice/GetInvoice/@x.InvoiceID" class="btn btn-warning">Güncelle</a></td>
    <td><a href="/Invoice/InvoiceDetail/@x.InvoiceID" class="btn btn-default" style="background-color:lightcoral;color:white;">Detaylar</a></td>
    <td><a href="/Invoice/InvoiceDetail/@x.InvoiceID" class="btn btn-default" style="background-color:thistle;color:white;">Kalem</a></td>
</tr>
    }
</table>
<a href="/Invoice/AddInvoice/" class="btn btn-primary">Yeni Fatura Girişi</a>
<br />
<br />
<button type="button" class="btn btn-primary" style="background-color:#d95151; color:white" data-toggle="modal" data-target="#Modal1">Popup Penceresi</button>

<div class="modal" id="Modal1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Popup Diyalog Ekranı</h2>
            </div>
            <div class="modal-body">
                <table class="table table-bordered">
                    <tr>
                        <td>Seri No</td>
                        <td>Sıra No</td>
                        <td>Tutar</td>
                    </tr>
                    @foreach (var x in Model)
                    {
                        <tr>
                            <td>@x.InvoiceSerialNo</td>
                            <td>@x.InvoiceSequenceNo</td>
                            <td>@x.Total</td>
                        </tr>
                    }
                </table>
                <button type="button" class="btn btn-danger" data-dismiss="modal">Tamam</button>
            </div>
        </div>
    </div>
</div>




