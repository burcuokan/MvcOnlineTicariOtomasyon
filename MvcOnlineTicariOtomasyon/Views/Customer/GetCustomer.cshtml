@model MvcOnlineTicariOtomasyon.Models.Entities.Customer
@{
    ViewBag.Title = "GetCustomer";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />
<h2>Müşteri Güncelleme</h2>
<br />
@using (Html.BeginForm("UpdateCustomer", "Customer", FormMethod.Post))
{
<div class="form-group">
    @Html.HiddenFor(x => x.CustomerID)
    @Html.HiddenFor(x => x.Situation)
    <label>Müşteri Adı</label>
    @Html.TextBoxFor(x => x.CustomerName, new { @class = "form-control" })
    @Html.ValidationMessageFor(x => x.CustomerName, "", new { @style = "color:red" })
    <br />
    <label>Soyad</label>
    @Html.TextBoxFor(x => x.CustomerSurname, new { @class = "form-control" })
    @Html.ValidationMessageFor(x => x.CustomerSurname, "", new { @style = "color:red" })
    <br />
    <label>Şehir</label>
    @Html.TextBoxFor(x => x.CustomerCity, new { @class = "form-control" })
    <br />
    <label>Mail</label>
    @Html.TextBoxFor(x => x.CustomerMail, new { @class = "form-control" })
    <br />
    <button class="btn btn-warning">Güncelle</button>
</div>
}


