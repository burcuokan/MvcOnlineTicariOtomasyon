@model MvcOnlineTicariOtomasyon.Models.Entities.CargoDetail
@{
    ViewBag.Title = "NewCargo";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />
<h2>Yeni Kargo Bilgisi Sayfası</h2>
<form class="form-group" method="post">
    <label>Takip Kodu</label>
    <input type="text" value="@ViewBag.trackingcode" class="form-control" readonly name="TrackingCode" />
    <br />
    <label>Personel</label>
    @Html.TextBoxFor(x => x.Employee, new { @class = "form-control" })
    <br />
    <label>Alıcı</label>
    @Html.TextBoxFor(x => x.Buyer, new { @class = "form-control" })
    <br />
    <label>Tarih</label>
    <input type="date" class="form-control" name="Date" />
    <br />
    <label>Açıklama</label>
    @Html.TextAreaFor(x => x.Explanation, new { @class = "form-control" })
    <br />
    <button class="btn btn-info">Kaydet</button>
</form>



