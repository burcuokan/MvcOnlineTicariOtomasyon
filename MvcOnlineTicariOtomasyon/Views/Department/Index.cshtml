@using MvcOnlineTicariOtomasyon.Models.Entities
@model List<Department> 
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />
<h2>Departmanlar</h2>
<table class="table table-bordered">
    <tr>
        <th>ID</th>
        <th>Departman Adı</th>
        <th>Sil</th>
        <th>Güncelle</th>
        <th>Detaylar</th>
    </tr>
    @foreach (var x in Model)
    {
        <tr>
            <td>@x.DepartmentID</td>
            <td>@x.DepartmentName</td>
            <td><a href="/Department/DeleteDepartment/@x.DepartmentID" class="btn btn-danger">Sil</a></td>
            <td><a href="/Department/GetDepartment/@x.DepartmentID" class="btn btn-success">Güncelle</a></td>
            <td><a href="/Department/DepartmentDetail/@x.DepartmentID" class="btn btn-default" style="background-color:lightcoral;color:white;">Detaylar</a></td>
        </tr>
    }
</table>
<a href="/Department/AddDepartment/" class="btn btn-primary">Departman Ekle</a>


