@using MvcOnlineTicariOtomasyon.Models.Entities
@model List<CargoDetail>
@{
    ViewBag.Title = "CargoTracking";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

<br />
@using (Html.BeginForm("CargoTracking", "CustomerPanel", FormMethod.Get))
{
    <p>
        Kargo Takip Numarası: @Html.TextBox("p")
        <input type="submit" value="Ara" />
    </p>
}
<table class="table table-bordered">
    <tr>
        <th>Personel</th>
        <th>Alıcı</th>
        <th>Takip Kodu</th>
        <th>Tarih</th>
        <th>Detaylar</th>
    </tr>
    @foreach (var x in Model)
    {
        <tr>
            <td>@x.Employee</td>
            <td>@x.Buyer</td>
            <td>@x.TrackingCode</td>
            <td>@x.Date</td>
            <td><a href="/CustomerPanel/CustomerCargoTracking/@x.TrackingCode" class="btn btn-default" style="background-color:lightcoral;color:white;">Detaylar</a></td>
        </tr>
    }
</table>


